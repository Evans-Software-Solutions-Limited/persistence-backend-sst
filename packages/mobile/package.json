{
  "name": "@persistence/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests --coverage",
    "build": "echo 'Mobile build handled by EAS'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~53.0.0-preview.7",
    "expo-build-properties": "~0.14.5",
    "expo-constants": "~17.1.6",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.0.6",
    "expo-splash-screen": "~0.30.8",
    "expo-sqlite": "~15.2.1",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.0.10",
    "eslint": "^9.0.0",
    "@babel/runtime": "^7.25.0",
    "babel-preset-expo": "~12.0.0-preview.6",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.5",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.{ts,tsx}",
      "**/*.test.{ts,tsx}"
    ],
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.bun/.*/)?(react-native|@react-native|@react-native-community|expo|@expo|expo-modules-core|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-svg)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/domain/services/**/*.ts",
      "src/application/**/*.ts",
      "src/ui/containers/**/*.{ts,tsx}",
      "src/ui/presenters/**/*.{ts,tsx}",
      "src/ui/hooks/**/*.{ts,tsx}",
      "src/ui/components/**/*.{ts,tsx}",
      "src/shared/errors/**/*.ts",
      "src/shared/utils/**/*.ts",
      "!**/*.types.ts",
      "!**/index.ts",
      "!**/__tests__/**",
      "!**/ports/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
