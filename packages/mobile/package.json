{
  "name": "@persistence/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests --coverage",
    "build": "echo 'Mobile build handled by EAS'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@kingstinct/react-native-healthkit": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stripe/stripe-react-native": "^0.61.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.62.0",
    "@tamagui/animations-react-native": "^2.0.0-rc.40",
    "@tamagui/babel-plugin": "^2.0.0-rc.40",
    "@tamagui/core": "^2.0.0-rc.40",
    "expo": "^55.0.0",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-device": "^55.0.15",
    "expo-image-manipulator": "^55.0.16",
    "expo-image-picker": "^55.0.20",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "^55.0.14",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "2.31.1",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.{ts,tsx}",
      "**/*.test.{ts,tsx}"
    ],
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.bun/.*/)?(react-native|@react-native|@react-native-community|expo|expo-[^/]*|@expo|expo-modules-core|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-svg|tamagui|@tamagui|react-native-reanimated|react-native-worklets)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/domain/services/**/*.ts",
      "src/application/**/*.ts",
      "src/ui/containers/**/*.{ts,tsx}",
      "src/ui/presenters/**/*.{ts,tsx}",
      "src/ui/hooks/**/*.{ts,tsx}",
      "src/ui/components/**/*.{ts,tsx}",
      "src/ui/theme/**/*.{ts,tsx}",
      "src/shared/errors/**/*.ts",
      "src/shared/utils/**/*.ts",
      "!**/*.types.ts",
      "!**/index.ts",
      "!**/__tests__/**",
      "!**/ports/**",
      "!src/ui/components/workouts/SemiCircleSlider/SemiCircleSlider.tsx",
      "!src/ui/components/workouts/SemiCircleSlider/SemiCircleSliderGesture.tsx",
      "!src/ui/components/workouts/SemiCircleSlider/Cursor.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
