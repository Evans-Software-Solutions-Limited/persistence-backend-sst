# Local-dev env for `expo run:ios` / `expo run:android`. Copy to .env, edit if needed.
#
# Staging + production builds DO NOT read this file — those builds inject
# EXPO_PUBLIC_* vars via eas.json (build.staging.env / build.production.env).
# So everything here is just for the local sim against the staging backend
# (the default) or your own SST dev stage (override EXPO_PUBLIC_API_URL).

# API base URL.
#   default — staging (works against deployed backend, no SST dev needed)
#   SST dev — override with the URL printed by `bun run sst dev --stage <name>`
EXPO_PUBLIC_API_URL=https://api.staging.persistence.evans-software-solutions.com

# Supabase project — auth only, never direct DB queries from the app.
EXPO_PUBLIC_SUPABASE_URL=https://dfeyebgdktfteqlacmru.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe publishable key — safe to embed in clients (designed to be public).
# Local builds always use the test/sandbox key; production builds use pk_live_ via eas.json.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_sandbox_key_here
