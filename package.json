{
  "name": "persistence",
  "version": "1.0.0",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "microservices/*"
  ],
  "scripts": {
    "dev": "sst dev",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "typecheck": "turbo run typecheck --cache-dir .turbo",
    "lint": "turbo run lint --cache-dir .turbo",
    "build": "turbo run build --cache-dir .turbo",
    "test": "turbo run test:unit --cache-dir .turbo",
    "test:unit": "turbo run test:unit --cache-dir .turbo",
    "tear-down": "sst remove",
    "shell": "bun run --filter @persistence/scripts shell"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22",
    "prettier": "3.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "dependencies": {
    "sst": "^3"
  }
}
